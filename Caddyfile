# Caddy · reverse proxy + HTTPS automático (Let's Encrypt)
# Variables vienen del .env (DOMAIN, ACME_EMAIL)
{
	email {$ACME_EMAIL}
}

# App principal: web (Next.js) + API (NestJS) bajo /api
{$DOMAIN} {
	# /api/* -> backend NestJS (se PRESERVA el prefijo /api; Nest usa setGlobalPrefix('api'))
	handle /api/* {
		reverse_proxy api:3001
	}
	# Todo lo demás -> frontend Next.js
	handle {
		reverse_proxy web:3000
	}
	encode gzip zstd

	# Cabeceras de seguridad para TODO el sitio (front Next + API).
	# HSTS lo emite Caddy porque termina el TLS. La CSP de la API la aplica helmet.
	header {
		-Server
		Strict-Transport-Security "max-age=15552000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "no-referrer"
		X-XSS-Protection "0"
		# NO se define Content-Security-Policy aquí. A propósito.
		# El front la emite por request desde apps/web/middleware.ts con un nonce
		# ('script-src 'self' 'nonce-<n>' 'strict-dynamic'', sin 'unsafe-inline').
		# La API la emite helmet. Si Caddy añadiese además la suya, el navegador
		# aplicaría AMBAS y una CSP es restrictiva por INTERSECCIÓN: la vieja
		# política no tiene el nonce, así que bloquearía los scripts de Next y
		# dejaría la app en blanco. Una sola CSP por respuesta.
		# Se elimina también de aquí la CSP permisiva que llevaba 'unsafe-inline'
		# en script-src (hallazgo de pentest).
	}
}

# BI (Metabase) en subdominio
bi.{$DOMAIN} {
	reverse_proxy metabase:3000
	encode gzip zstd
	header {
		-Server
		Strict-Transport-Security "max-age=15552000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
	}
}

