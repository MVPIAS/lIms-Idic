# Caddy · reverse proxy + HTTPS automático (Let's Encrypt)
# Variables vienen del .env (DOMAIN, ACME_EMAIL)
{
	email {$ACME_EMAIL}
}

# App principal: web (Next.js) + API (NestJS) bajo /api
{$DOMAIN} {
	# /api/* -> backend NestJS (se PRESERVA el prefijo /api; Nest usa setGlobalPrefix('api'))
	handle /api/* {
		reverse_proxy api:3001
	}
	# Todo lo demás -> frontend Next.js
	handle {
		reverse_proxy web:3000
	}
	encode gzip zstd

	# Cabeceras de seguridad para TODO el sitio (front Next + API).
	# HSTS lo emite Caddy porque termina el TLS. La CSP de la API la aplica helmet.
	header {
		-Server
		Strict-Transport-Security "max-age=15552000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "no-referrer"
		X-XSS-Protection "0"
		# CSP CONSERVADORA compatible con Next.js 14 (usa estilos/scripts inline
		# propios). 'unsafe-inline' en script/style es necesario para el runtime de
		# Next; endurecerla con nonces/hashes es trabajo futuro.
		Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; script-src 'self' 'unsafe-inline'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; object-src 'none'"
	}
}

# BI (Metabase) en subdominio
bi.{$DOMAIN} {
	reverse_proxy metabase:3000
	encode gzip zstd
	header {
		-Server
		Strict-Transport-Security "max-age=15552000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
	}
}

# Consola de MinIO (opcional) en subdominio — comentar si no se usa
