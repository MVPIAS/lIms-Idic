# =============================================================================
# LIMS IDIC · Preproducción · variables de entorno
# Copiar a ".env" y rellenar. NUNCA subir el .env real al repositorio.
# =============================================================================
# SEGURIDAD (obligatorio antes de exponer el servicio):
#   1. Genere cada secreto de forma ALEATORIA. Nunca reutilice valores ni deje
#      los placeholders "CAMBIAR_*" (la API aborta con un JWT_SECRET corto, pero
#      Postgres/MinIO SÍ arrancarían con una clave débil: es su responsabilidad).
#         POSTGRES_PASSWORD / MINIO_ROOT_PASSWORD:  openssl rand -base64 30
#         JWT_SECRET (>=32, recomendado 64):         openssl rand -hex 32
#   2. Restrinja los permisos del fichero: contiene TODAS las credenciales.
#         chmod 600 .env    # solo el propietario puede leerlo
#   3. En on-premise (datos FFAA) estos valores solo viven en el servidor del
#      cuartel y en el respaldo cifrado; jamás en git, chat ni correo.
# =============================================================================

# Dominio público (apuntar su DNS A-record a la IP del VPS)
DOMAIN=lims-idic-preprod.tudominio.cl
ACME_EMAIL=devops@aiuken.cl

# PostgreSQL  (contraseña fuerte y aleatoria: openssl rand -base64 30)
POSTGRES_USER=lims
POSTGRES_PASSWORD=CAMBIAR_password_fuerte_aleatorio_30+_chars
POSTGRES_DB=lims_idic

# Seguridad API
# JWT_SECRET: mínimo 32 caracteres. La API ABORTA el arranque si falta o es corto.
# Genérelo con: openssl rand -hex 32   (64 hex chars)
JWT_SECRET=CAMBIAR_secreto_largo_aleatorio_64_chars

# CORS: dominios permitidos separados por comas (sin "*"). OBLIGATORIO en producción.
CORS_ORIGINS=https://lims-idic-preprod.tudominio.cl

# MinIO (almacenamiento de documentos/certificados)
# NO use el usuario por defecto "minioadmin". Contraseña: openssl rand -base64 30
MINIO_ROOT_USER=lims-minio
MINIO_ROOT_PASSWORD=CAMBIAR_minio_password_fuerte_aleatorio

# Nota: en preproducción cloud van SOLO datos sintéticos / seeds.
# Datos reales del IDIC (RUTs, contratos FFAA) => únicamente on-premise.
