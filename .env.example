# =============================================================================
# LIMS IDIC · Variables de entorno
# Copiar a .env y ajustar según necesidad
# =============================================================================

# --- App general ---
NODE_ENV=development
TENANT_CODE=IDIC

# --- API (NestJS) ---
API_PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://lims:lims@localhost:5432/lims_idic?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# --- Redis (BullMQ + cache) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- MinIO (S3-compatible) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio-secret-key
S3_BUCKET=lims-idic
S3_REGION=us-east-1

# --- JWT ---
JWT_SECRET=cambiar-en-produccion-cadena-larga-y-aleatoria
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# --- LDAP / Active Directory ---
# En desarrollo, dejar LDAP_ENABLED=false para usar usuarios locales
LDAP_ENABLED=false
LDAP_URL=ldap://ad.ejercito.cl:389
LDAP_BIND_DN=CN=svc-lims,OU=ServiceAccounts,DC=ejercito,DC=cl
LDAP_BIND_CREDENTIALS=
LDAP_SEARCH_BASE=OU=IDIC,DC=ejercito,DC=cl
LDAP_SEARCH_FILTER=(sAMAccountName={{username}})

# --- 2FA (opcional) ---
TOTP_ENABLED=false
TOTP_ISSUER=LIMS IDIC

# --- Audit ---
AUDIT_ENABLED=true
AUDIT_LOG_RETENTION_MONTHS=84

# --- Sync con LIMS técnico (transición) ---
# Durante coexistencia con sistema legacy
LEGACY_LIMS_DB_URL=
LEGACY_COMERCIAL_DB_URL=

# --- Email (notificaciones) ---
SMTP_HOST=smtp.ejercito.cl
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="LIMS IDIC <lims@idic.cl>"
