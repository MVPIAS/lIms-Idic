  nombre        String?   @db.VarChar(200)
  tipoMuestraId String?   @map("tipo_muestra_id") @db.Uuid
  granGrupoId   String?   @map("gran_grupo_id") @db.Uuid
  grupoId       String?   @map("grupo_id") @db.Uuid
