/// Resultado de ensayo. Las columnas de estado/fórmula las habilita
/// `packages/db/align_resultado_estado.sql` (aplicar ANTES de desplegar esta
/// versión del modelo; el Dockerfile de la API corre `prisma generate` en el
/// build, así que el cliente se regenera solo al redesplegar).
model Resultado {
  id         String    @id @default(uuid()) @db.Uuid
  otId       String?   @map("ot_id") @db.Uuid
  muestraId  String    @map("muestra_id") @db.Uuid
  /// Analito LEGACY (tabla `analito`). Nullable: los resultados del PUENTE usan
  /// catAnalitoId en su lugar y dejan analitoId en NULL (align_puente_catalogo.sql).
  analitoId  String?   @map("analito_id") @db.Uuid
  replicas   Json      @default("[]")
  promedio   Decimal?  @db.Decimal(18, 6)
  desviacion Decimal?  @db.Decimal(18, 6)
  cv         Decimal?  @db.Decimal(8, 2)
  unidad     String?   @db.VarChar(30)
  veredicto  String?   @db.VarChar(20)
  analistaId String?   @map("analista_id") @db.Uuid
  fecha      DateTime  @default(now()) @db.Timestamptz
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz

  /// RF-D04.1/D04.2 · Equipo con el que se ejecutó el ensayo. OPCIONAL: NULL en
  /// resultados históricos y en capturas que no informan equipo. Cuando se
  /// informa, ResultadoService.capturar() llama a EquiposService.verificarApto()
  /// ANTES de persistir y BLOQUEA (409) si el equipo está descalibrado / fuera
  /// de servicio; sólo un equipo apto llega a guardarse aquí. Sin relación
  /// Prisma: la tabla `equipo` la gestiona equipos.module.ts vía SQL crudo
  /// (fuera del schema), igual que otros enlaces cross-dominio. La columna la
  /// añade packages/db/align_resultado_equipo.sql.
  equipoId   String?   @map("equipo_id") @db.Uuid

  /// RF-A06/D02.1 · Motor de fórmulas. `resultadoFinal` es el valor que
  /// devolvió la fórmula del analito (NULL si el analito no tiene fórmula: en
  /// ese caso el valor del ensayo es `promedio`). `formulaAplicada` es la copia
  /// del texto de la fórmula en el instante de la captura — `Analito.formula`
  /// es editable, y sin esta copia un resultado ya emitido dejaría de ser
  /// reproducible en cuanto alguien corrigiese la fórmula del catálogo.
  resultadoFinal   Decimal?  @map("resultado_final") @db.Decimal(18, 6)
  formulaAplicada  String?   @map("formula_aplicada")

  /// RF-E01 · Aprobación escalonada: capturado → revisado_n1 → aprobado
  /// (+ rechazado / devuelto hacia atrás). El vocabulario y las transiciones
  /// viven en `apps/api/src/common/estados.ts` (dominio "resultado").
  /// Las columnas físicas conservan el sufijo `_n1` que ya usaba schema.sql.
  estado           String    @default("capturado") @db.VarChar(20)
  revisadoPor      String?   @map("revisado_n1_por") @db.Uuid
  revisadoAt       DateTime? @map("revisado_n1_at") @db.Timestamptz
  aprobadoPor      String?   @map("aprobado_por") @db.Uuid
  aprobadoAt       DateTime? @map("aprobado_at") @db.Timestamptz
  motivoDevolucion String?   @map("motivo_devolucion")

  /// PUENTE catálogo v2 (align_puente_catalogo.sql). Un resultado del puente se
  /// materializa desde un cat_metodo/cat_analito del panel del elemento, con la
  /// especificación (limiteInf/nominal/limiteSup) y la fórmula ARRASTRADAS —
  /// copia congelada del catálogo en el instante de generar el análisis. En ese
  /// caso analitoId es NULL. `unidad`/`veredicto` (arriba) se reutilizan.
  catAnalitoId String? @map("cat_analito_id") @db.Uuid
  catMetodoId  String? @map("cat_metodo_id") @db.Uuid
  limiteInf    String? @map("limite_inf")
  nominal      String?
  limiteSup    String? @map("limite_sup")
  formula      String?
  /// Valor capturado del resultado del puente (columnas ya existentes en
  /// schema.sql, ahora mapeadas). `valorNumerico` cuando el valor es numérico
  /// (habilita el contraste con los límites); `valorTexto` guarda siempre la
  /// forma textual (admite resultados cualitativos: 'cumple', 'Declarado'…).
  valorNumerico Decimal? @map("valor_numerico") @db.Decimal(18, 6)
  valorTexto    String?  @map("valor_texto") @db.VarChar(120)

  muestra    Muestra   @relation(fields: [muestraId], references: [id], onDelete: Cascade)
  analito    Analito?  @relation(fields: [analitoId], references: [id])
  catAnalito CatAnalito? @relation(fields: [catAnalitoId], references: [id])
  catMetodo  CatMetodo?  @relation(fields: [catMetodoId], references: [id])

  @@index([otId])
  @@index([muestraId])
  @@index([estado, fecha])
  @@index([equipoId])
  @@index([catAnalitoId])
  @@index([catMetodoId])
  @@map("resultado")
}

