model SolicitudCosteo {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  cotizacionId  String    @map("cotizacion_id") @db.Uuid
  familiaId     String?   @map("familia_id") @db.Uuid
  catElementoId String?   @map("cat_elemento_id") @db.Uuid
  catEnsayoId   String?   @map("cat_ensayo_id") @db.Uuid
  glosa         String?
  horasHombre   Decimal   @default(0) @map("horas_hombre") @db.Decimal(10, 2)
  costoDirecto  Decimal   @default(0) @map("costo_directo") @db.Decimal(14, 2)
  estado        String    @default("solicitado") @db.VarChar(20)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  @@index([cotizacionId])
  @@index([familiaId])
  @@map("solicitud_costeo")
}

model OrdenInterna {
