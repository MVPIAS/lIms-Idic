model Certificado {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  otId            String    @map("ot_id") @db.Uuid
  codigo          String    @db.VarChar(40)
  tipo            String?   @db.VarChar(40)
  plantillaId     String?   @map("plantilla_id") @db.Uuid
  hashSha256      String?   @map("hash_sha256") @db.VarChar(64)
  urlVerificacion String?   @map("url_verificacion") @db.VarChar(300)
  // --- Emisión real (align_certificado.sql) ---
  // Correlativo CERT-AAAA-NNNN generado por el sistema. Se escribe también en
  // `codigo`, cuyo UNIQUE(tenantId, codigo) cierra la unicidad a nivel de BD.
  numero             String?   @db.VarChar(30)
  // Código corto imprimible para validar el certificado en papel (anti-repudio).
  codigoVerificacion String?   @map("codigo_verificacion") @db.VarChar(24)
  // HTML canónico sellado: sha256(documentoHtml) == hashSha256. Es lo que hace
  // la verificación reproducible aunque los resultados de la OT cambien luego.
  documentoHtml      String?   @map("documento_html")
  emitidoPor         String?   @map("emitido_por") @db.Uuid
  fecha           DateTime  @default(now()) @db.Timestamptz
  estado          String    @default("emitido") @db.VarChar(20)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  plantilla       PlantillaInforme? @relation(fields: [plantillaId], references: [id])
  ot              OrdenTrabajo      @relation(fields: [otId], references: [id])

  @@unique([tenantId, codigo])
  @@index([otId])
  @@index([codigoVerificacion])
  @@map("certificado")
}

